{% extends "./_base.njk" %}


{% block body %}
    <div class="bg-primary py-4">
        <header class="container">
            <section class="navbar navbar-expand sticky-top navbar-dark">
                <a class="navbar-brand" href="/">
                    <img
                        src="{{ '/assets/images/logo-horizontalni.min.svg'|url }}"
                        alt="Veterina Smíchov"
                        width="7000" height="1800"
                        class="img-fluid"
                    >
                </a>
                <nav class="navbar-nav ml-auto">
                    {% include "navigation.njk" %}
                </nav>
            </section>
        </header>

        {% block headerExtra %}{% endblock %}
    </div>


    <div class="container">
        {% if generalAnnouncements.showAnnoucements %}
            <aside class="container py-4">
                <div class="alert alert-secondary d-inline-block fs-4">
                    {{ generalAnnouncements.body|markdown|safe }}
                </div>
            </aside>
        {% endif %}
        <main class="py-5">
            <h1 class="display-1">
                {% block title %}
                    {#                    {{ title|safe }} #}
                {% endblock %}
            </h1>
            {% block content %}
                {{ content|safe }}
            {% endblock %}
        </main>
    </div>

    <footer class="bg-teal-900 p-5">
        <div class="container fw-bold">
            {{ footer.content|markdown|safe }}
        </div>
    </footer>
{% endblock %}
