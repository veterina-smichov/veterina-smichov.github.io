     },
     {
     label: 'Inner Range Start',
     name: 'innerStartDate',
     widget: 'dateRangeValidator'
     },
     {
     label: 'Inner Range End',
     name: 'innerEndDate',
     widget: 'dateRangeValidator'
     }
     ]
     */

    CMS.registerPreviewStyle('/assets/styles/styles.scss')
</script>
